    </div>
    <div class="fg"><div class="lbl">Amount Received (₹) *</div>
      <input class="inp" type="number" id="pay-amount" placeholder="${(bal).toFixed(0)}" style="font-size:1.1rem;background:#1c1c1c!important;color:#f2ede8!important;-webkit-text-fill-color:#f2ede8!important;-webkit-appearance:none;">
