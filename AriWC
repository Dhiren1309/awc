async function renderSupplier(){
  const all=await dbGet('payables');
  // Group by supplier
  const grouped={};
  all.forEach(p=>{
    if(!grouped[p.supplier]) grouped[p.supplier]={supplier:p.supplier,totalDue:0,entries:[]};
    grouped[p.supplier].totalDue+=p.balance||0;
    grouped[p.supplier].entries.push(p);
  });
  const suppliers=Object.values(grouped).filter(s=>s.totalDue>0);
  const totalDue=suppliers.reduce((s,x)=>s+x.totalDue,0);
  document.getElementById('sp-total').textContent=fmt(totalDue);
  document.getElementById('sp-count').textContent=suppliers.length;

  const el=document.getElementById('supplier-list');
  if(!suppliers.length){
    el.innerHTML=`<div class="empty"><div class="empty-icon">🏦</div><div class="empty-text">No pending supplier payments.<br>All clear!</div></div>`;
    return;
  }
  el.innerHTML=suppliers.map(s=>`
    <div class="card" style="margin-bottom:10px">
      <div style="display:flex;justify-content:space-between;align-items:start;margin-bottom:8px">
        <div>
          <div style="font-size:14px;font-weight:700">${s.supplier}</div>
          <div style="font-size:11px;color:var(--muted)">${s.entries.length} purchase(s)</div>
        </div>
        <div style="text-align:right">
          <div style="font-size:16px;font-weight:800;color:var(--red)">${fmt(s.totalDue)}</div>
          <div style="font-size:10px;color:var(--muted)">Total Due</div>
        </div>
      </div>
      ${s.entries.filter(e=>e.balance>0).map(e=>`
        <div class="card2" style="margin-bottom:6px">
          <div style="display:flex;justify-content:space-between;align-items:center">
            <div>
              <div style="font-size:12px;font-weight:700">${e.material||'Material'}</div>
              <div style="font-size:11px;color:var(--muted)">Bill: ${fmt(e.totalBill)} · Paid: ${fmt(e.paid||0)}</div>
              ${e.dueDate?`<div style="font-size:10px;color:var(--orange)">Due: ${e.dueDate}</div>`:''}
            </div>
            <div style="display:flex;flex-direction:column;gap:4px;align-items:flex-end">
              <div style="font-size:13px;font-weight:800;color:var(--red)">${fmt(e.balance)}</div>
              <button onclick="openPaySupplier('${e.id}')" style="background:var(--green);border:none;color:#000;padding:5px 10px;border-radius:7px;font-size:10px;font-weight:700;cursor:pointer">💰 Pay</button>
            </div>
          </div>
        </div>`).join('')}
    </div>`).join('');
}

