// ── DASHBOARD ──
async function refreshDash(){
  const [custs,orders,accounts,rawstock,salesstock]=await Promise.all([
    dbGet('customers'),dbGet('orders'),dbGet('accounts'),dbGet('rawstock'),dbGet('salesstock')
  ]);
  // Pending = all unpaid balance regardless of delivery status
  const pendingAmt=orders.filter(o=>o.status!=='cancelled'&&(o.balance||0)>0).reduce((s,o)=>s+(o.balance||0),0);
  const income=accounts.filter(e=>e.type==='income').reduce((s,e)=>s+e.amount,0);
  const expense=accounts.filter(e=>e.type==='expense').reduce((s,e)=>s+e.amount,0);
  // Raw stock value = remaining kg × purchase price
  const rawStockValue=rawstock.reduce((s,r)=>s+((r.remaining||r.qty||0)*(r.price||0)),0);
  // Sales stock value = bundles × selling price
  const salesStockValue=salesstock.reduce((s,x)=>s+(x.bundles||0)*(x.sellingPrice||0),0);
  const lowStockItems=rawstock.filter(r=>r.minStock>0&&(r.remaining||0)<=r.minStock);

  document.getElementById('d-cust').textContent=custs.length;
  document.getElementById('d-orders').textContent=orders.length;
  document.getElementById('d-pending').textContent=fmtK(pendingAmt);
  document.getElementById('d-balance').textContent=fmtK(income-expense);
  document.getElementById('d-rawstock').textContent=fmtK(rawStockValue);
  document.getElementById('d-salesstock').textContent=fmtK(salesStockValue);

  // Recent orders
  const ro=orders.slice(-3).reverse();
  document.getElementById('d-recent-orders').innerHTML=ro.length?ro.map(o=>`
    <div style="display:flex;justify-content:space-between;padding:7px 0;border-bottom:1px solid var(--border)">
      <div><div style="font-size:12px;font-weight:700">${o.custName}</div><div style="font-size:10px;color:var(--muted)">${o.product.substring(0,28)}...</div></div>
      <div style="text-align:right"><div style="font-size:12px;font-weight:700;color:var(--gold)">${fmt(o.total)}</div><span class="badge ${o.status==='delivered'?'bg-green':o.status==='cancelled'?'bg-red':'bg-blue'}" style="font-size:8px">${o.status}</span></div>
    </div>`).join(''):`<div style="font-size:12px;color:var(--muted);text-align:center;padding:8px">No orders yet</div>`;

  // Recent accounts - sort by date desc
  const ra=[...accounts].sort((a,b)=>new Date(b.created)-new Date(a.created)).slice(0,3);
  document.getElementById('d-recent-acc').innerHTML=ra.length?ra.map(e=>`
    <div style="display:flex;justify-content:space-between;padding:7px 0;border-bottom:1px solid var(--border)">
      <div><div style="font-size:12px;font-weight:700">${e.category.replace('_',' ')}</div><div style="font-size:10px;color:var(--muted)">${e.date}</div></div>
      <div style="font-size:13px;font-weight:700;color:${e.type==='income'?'var(--green)':'var(--red)'}">${e.type==='income'?'+':'−'}${fmt(e.amount)}</div>
    </div>`).join(''):`<div style="font-size:12px;color:var(--muted);text-align:center;padding:8px">No transactions yet</div>`;

  // Low stock
  document.getElementById('d-low-stock').innerHTML=lowStockItems.length?lowStockItems.map(r=>`
    <div style="display:flex;justify-content:space-between;padding:6px 0;border-bottom:1px solid var(--border)">
      <div style="font-size:12px;font-weight:700;color:var(--red)">⚠️ ${r.matType==='metal'?r.metalType+' '+r.dia+'mm':r.supplier+'/'+r.grade}</div>
      <div style="font-size:12px;color:var(--red)">${(r.remaining||0).toFixed(1)}kg left</div>
    </div>`).join(''):`<div style="font-size:12px;color:var(--muted);text-align:center;padding:8px">No alerts 👍</div>`;
}



