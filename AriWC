// ══════════════════════════════════════════
// CALCULATOR
// ══════════════════════════════════════════
// Km = (π/4) × density(g/cm³) — correct wire weight formula
// Copper=8.96g/cm³, Aluminium=2.70g/cm³, CCS≈8.0g/cm³
const KM = {copper:7.037,aluminium:2.121,ccs_nonmag:6.283,ccs_mag:6.283};

