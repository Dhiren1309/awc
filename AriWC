let _challanOrderId = null;
let _challanItems = [];

async function openChallanModal(orderId){
  _challanOrderId = orderId;
  const orders=await dbGet('orders');
  const o=orders.find(x=>x.id===orderId);
  if(!o) return;

  // Get customer pending balance from other orders
  const allOrders=await dbGet('orders');
  const prevBal=allOrders
    .filter(x=>x.custId===o.custId && x.id!==orderId && x.status!=='cancelled' && (x.balance||0)>0)
    .reduce((s,x)=>s+(x.balance||0),0);

  document.getElementById('challan-order-info').innerHTML=`
    <div style="font-size:13px;font-weight:700">${o.custName||'Customer'}</div>
    <div style="font-size:11px;color:var(--muted)">${o.product||''} · ${o.qty||0} ${o.unit||'Bundles'}</div>
  `;

  // Pre-fill one item from order
  _challanItems = [{
    brand: o.product||'',
    bundleLen: '',
    qty: o.qty||1,
    rate: o.rate||0,
    total: o.total||0
  }];
  renderChallanItems();

  document.getElementById('challan-prev-bal').value = prevBal>0 ? prevBal.toFixed(0) : '';
  updateChallanTotal();
  closeModal('modal-vieworder');
  openModal('modal-challan');
}

function renderChallanItems(){
  const el=document.getElementById('challan-items-list');
  el.innerHTML=_challanItems.map((item,i)=>`
