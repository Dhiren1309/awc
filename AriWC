// ── BACKUP & RESTORE ──
async function exportBackup(){
  const backup={version:1,exported:new Date().toISOString()};
  for(const store of ['customers','orders','accounts','production','rawstock','salesstock','recipes','quotations']){
    backup[store]=await dbGet(store);
  }
  const blob=new Blob([JSON.stringify(backup,null,2)],{type:'application/json'});
  const url=URL.createObjectURL(blob);
  const a=document.createElement('a');
  a.href=url;
  a.download='AWC_Backup_'+today()+'.json';
  a.click();
  URL.revokeObjectURL(url);
  showToast('Backup downloaded ✓');
}

async function restoreBackup(input){
  const file=input.files[0];
  if(!file) return;
  if(!await awcConfirm('Replace ALL data with backup?','⚠️ This cannot be undone. Current data will be lost.')) return;
  const text=await file.text();
  let backup;
  try{ backup=JSON.parse(text); }
  catch(e){ showToast('Invalid backup file','var(--red)'); return; }
  for(const store of ['customers','orders','accounts','production','rawstock','salesstock','recipes','quotations']){
    if(!backup[store]) continue;
    const tx=db.transaction(store,'readwrite');
    const clearReq=tx.objectStore(store).clear();
    await new Promise((res,rej)=>{ clearReq.onsuccess=res; clearReq.onerror=rej; });
    for(const item of backup[store]){
      await dbPut(store,item);
    }
  }
  closeModal('modal-backup');
  showToast('Backup restored ✓');
  refreshDash();
}

