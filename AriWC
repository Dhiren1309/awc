// Inner % change → update outer display
document.getElementById('c-inner-pct').addEventListener('input',function(){
  document.getElementById('outer-pct-display').textContent=(100-parseFloat(this.value||0))+'%';
});

let lastCalcResult = null;

function getCalcLength(){
  const t = document.getElementById('c-wiretype').value;
  if(t!=='twisted') return parseFloat(document.getElementById('c-length').value)||100;
  const mode = document.getElementById('c-twist-mode').value;
  if(mode==='input') return parseFloat(document.getElementById('c-twist-input').value)||90;
  return parseFloat(document.getElementById('c-twist-output').value)/0.955||100;
}

function doCalculate(){
  const wireType = document.getElementById('c-wiretype').value;
  const metalType = document.getElementById('c-metaltype').value;
  const length = getCalcLength();
  const waste = parseFloat(document.getElementById('c-waste').value)||2;
  const oh = parseFloat(document.getElementById('c-oh').value)||0;
  const lab = parseFloat(document.getElementById('c-lab').value)||0;
  const margin = parseFloat(document.getElementById('c-margin').value)||15;
  const mbPct = parseFloat(document.getElementById('c-mb-pct').value)||0;
  const mbRate = parseFloat(document.getElementById('c-mb-rate').value)||0;

  let metalWt=0, metalCost=0, rows=[];

  // Metal weight
  if(metalType==='copper_ccs'){
    const cuS=parseFloat(document.getElementById('c-cu-strands').value)||2;
    const cuD=parseFloat(document.getElementById('c-cu-dia').value)||0.12;
    const cuR=parseFloat(document.getElementById('c-cu-rate').value)||375;
    const ccsKm=parseFloat(document.getElementById('c-ccs-type').value)||6.16;
    const ccsS=parseFloat(document.getElementById('c-ccs-strands').value)||3;
    const ccsD=parseFloat(document.getElementById('c-ccs-dia').value)||0.12;
    const ccsR=parseFloat(document.getElementById('c-ccs-rate').value)||875;
    const cuWt=cuS*cuD*cuD*KM.copper*length;
    const ccsWt=ccsS*ccsD*ccsD*ccsKm*length;
    metalWt=cuWt+ccsWt;
    metalCost=(cuWt/1000)*cuR+(ccsWt/1000)*ccsR;
    rows.push({l:`Copper (${cuS}×${cuD}mm)`,v:fmtG(cuWt)});
    rows.push({l:`CCS (${ccsS}×${ccsD}mm)`,v:fmtG(ccsWt)});
  } else {
    const s=parseFloat(document.getElementById('c-strands').value)||7;
    const d=parseFloat(document.getElementById('c-dia').value)||0.711;
    const r=parseFloat(document.getElementById('c-mrate').value)||375;
    metalWt=s*d*d*(KM[metalType]||7.03)*length;
    metalCost=(metalWt/1000)*r;
    rows.push({l:`Metal Weight (${s}×${d}mm)`,v:fmtG(metalWt)});
  }

  let pvcWt=0, pvcCost=0, innerWt=0, outerWt=0;

  if(wireType==='single'){
    const od=parseFloat(document.getElementById('c-od-single').value)||2.5;
    const kp=parseFloat(document.getElementById('c-kp-single').value)||1.50;
    const pr=parseFloat(document.getElementById('c-pvcrate-single').value)||72;
    const totalBundleWt=od*od*kp*length;
    pvcWt=totalBundleWt-metalWt;
    pvcCost=(pvcWt/1000)*pr;
    rows.push({l:`Total Bundle Wt (OD² × Kp × L)`,v:fmtG(totalBundleWt)});
    rows.push({l:`PVC Weight`,v:fmtG(pvcWt)});

  } else if(wireType==='double'||wireType==='twisted'){
    const od=parseFloat(document.getElementById('c-od-double').value)||3.0;
    const innerPct=parseFloat(document.getElementById('c-inner-pct').value)||75;
    const outerPct=100-innerPct;
    const innerKp=parseFloat(document.getElementById('c-inner-kp').value)||1.45;
    const outerKp=parseFloat(document.getElementById('c-outer-kp').value)||1.50;
    const innerRate=parseFloat(document.getElementById('c-inner-rate').value)||68;
    const outerRate=parseFloat(document.getElementById('c-outer-rate').value)||72;
    const totalBundleWt=od*od*((innerKp*innerPct/100)+(outerKp*outerPct/100))*length;
    pvcWt=totalBundleWt-metalWt;
    innerWt=pvcWt*(innerPct/100);
    outerWt=pvcWt*(outerPct/100);
    pvcCost=(innerWt/1000)*innerRate+(outerWt/1000)*outerRate;
    rows.push({l:`Total PVC Weight`,v:fmtG(pvcWt)});
    rows.push({l:`Inner PVC (${innerPct}%)`,v:fmtG(innerWt)});
    rows.push({l:`Outer PVC (${outerPct}%)`,v:fmtG(outerWt)});

  } else {
    // Multicore
    const cores=parseInt(document.getElementById('c-cores').value)||2;
    const coreOD=parseFloat(document.getElementById('c-core-od').value)||2.0;
    const coreKp=parseFloat(document.getElementById('c-core-kp').value)||1.45;
    const corePvcRate=parseFloat(document.getElementById('c-core-pvcrate').value)||68;
    const finalOD=parseFloat(document.getElementById('c-final-od').value)||7.0;
    const innerShPct=parseFloat(document.getElementById('c-sheath-inner-pct').value)||60;
    const outerShPct=100-innerShPct;
    const innerShKp=parseFloat(document.getElementById('c-sheath-inner-kp').value)||1.45;
    const outerShKp=parseFloat(document.getElementById('c-sheath-outer-kp').value)||1.50;
    const innerShRate=parseFloat(document.getElementById('c-sheath-inner-rate').value)||68;
    const outerShRate=parseFloat(document.getElementById('c-sheath-outer-rate').value)||95;

    // FIX: metalWt above is for 1 core — multiply by number of cores
    const totalMetalWt=metalWt*cores;
    metalCost=metalCost*cores;
    const coreBundleWt=coreOD*coreOD*coreKp*length*cores;
    const corePvcWt=coreBundleWt-totalMetalWt;
    const finalBundleWt=finalOD*finalOD*((innerShKp*innerShPct/100)+(outerShKp*outerShPct/100))*length;
    const sheathWt=finalBundleWt-totalMetalWt-corePvcWt;
    const innerShWt=sheathWt*(innerShPct/100);
    const outerShWt=sheathWt*(outerShPct/100);
    pvcWt=corePvcWt+(sheathWt>0?sheathWt:0);
    pvcCost=(corePvcWt/1000)*corePvcRate+(innerShWt/1000)*innerShRate+(outerShWt/1000)*outerShRate;
    innerWt=corePvcWt+innerShWt;
    outerWt=outerShWt;
    metalWt=totalMetalWt; // update metalWt to total for all cores for summary rows
    rows.push({l:`Metal Weight (${cores} cores × 1 core wt)`,v:fmtG(totalMetalWt)});
    rows.push({l:`Core PVC (${cores} cores, OD ${coreOD}mm)`,v:fmtG(corePvcWt)});
    rows.push({l:`Inner Sheath (${innerShPct}%)`,v:fmtG(innerShWt>0?innerShWt:0)});
    rows.push({l:`Outer Sheath (${outerShPct}%)`,v:fmtG(outerShWt>0?outerShWt:0)});
  }

  // Masterbatch
  const mbWt=(pvcWt*(mbPct/100));
  const mbCost=(mbWt/1000)*mbRate;
  if(mbPct>0) rows.push({l:`Masterbatch (${mbPct}% of PVC)`,v:fmtG(mbWt)});

  const totalWt=(metalWt+pvcWt+mbWt)*(1+waste/100);
  const matCost=(metalCost+pvcCost+mbCost)*(1+waste/100);
  const costPrice=matCost+oh+lab;
  const profit=costPrice*(margin/100);
  const sellPrice=costPrice+profit;
  const outputLen = wireType==='twisted'?length*0.955:length;

  rows.push({l:'─────',v:'─────'});
  rows.push({l:'Total Metal Weight',v:fmtG(metalWt)});
  rows.push({l:'Total PVC Weight',v:fmtG(pvcWt)});
  rows.push({l:'Total Bundle Weight',v:fmtG(totalWt)});
  rows.push({l:'Material Cost',v:fmt(matCost)});
  rows.push({l:'Cost Price',v:fmt(costPrice)});
  rows.push({l:'Profit ('+margin+'%)',v:fmt(profit)});
  if(wireType==='twisted') rows.push({l:'Output Length',v:outputLen.toFixed(2)+'m'});
  rows.push({l:'Per Meter',v:fmt(sellPrice/outputLen)+'/m'});
  rows.push({l:'Per Kg',v:fmt(sellPrice/(totalWt/1000))+'/kg'});

  document.getElementById('r-sell').textContent=fmt(sellPrice);
  document.getElementById('r-rows').innerHTML=rows.map(r=>
    r.l==='─────'?`<div class="divider" style="margin:4px 0"></div>`:
    `<div class="result-row"><span>${r.l}</span><span class="result-val">${r.v}</span></div>`
  ).join('');
  document.getElementById('calc-result').style.display='block';
  document.getElementById('calc-result').scrollIntoView({behavior:'smooth',block:'start'});

  lastCalcResult={wireType,metalType,length,outputLen,sellPrice,costPrice,profit,metalWt,pvcWt,mbWt,totalWt,innerWt,outerWt,rows};
}

