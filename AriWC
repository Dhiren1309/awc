async function askAI(question){
  const chatEl=document.getElementById('ai-chat');
  if(!chatEl) return;

  // Show user message
  chatEl.innerHTML+=`<div style="text-align:right;margin-bottom:8px">
    <div style="display:inline-block;background:var(--gold);color:#000;border-radius:12px 12px 2px 12px;padding:8px 12px;font-size:13px;max-width:85%;font-weight:600">${question}</div>
  </div>`;

  // Show typing indicator
  const typingId='typing-'+Date.now();
  chatEl.innerHTML+=`<div id="${typingId}" style="margin-bottom:8px">
    <div style="display:inline-block;background:var(--card2);border-radius:12px 12px 12px 2px;padding:8px 12px;font-size:13px;color:var(--muted)">🤖 Thinking...</div>
  </div>`;
  chatEl.scrollTop=chatEl.scrollHeight;

  try{
    const context=await getBusinessContext();
    const reqBody={
      contents:[{role:'user',parts:[{text:context+'\n\nUser question: '+question}]}],
      generationConfig:{maxOutputTokens:500,temperature:0.7,topP:0.9}
    };
    const response=await fetch(GEMINI_URL,{
      method:'POST',
      headers:{
        'Content-Type':'application/json',
        'x-goog-api-key':GEMINI_API_KEY
      },
      body:JSON.stringify(reqBody)
    });
    if(!response.ok){
      const errData=await response.json().catch(()=>({}));
      throw new Error('API error: '+(errData?.error?.message||response.status));
    }
    const data=await response.json();
    const answer=data?.candidates?.[0]?.content?.parts?.[0]?.text||'No response received. Please try again.';

    // Remove typing indicator
    document.getElementById(typingId)?.remove();

    // Show AI response
    chatEl.innerHTML+=`<div style="margin-bottom:8px">
      <div style="display:inline-block;background:var(--card2);border-radius:12px 12px 12px 2px;padding:10px 12px;font-size:13px;color:var(--text);max-width:92%;line-height:1.5">${answer.replace(/\n/g,'<br>').replace(/\*\*(.*?)\*\*/g,'<b>$1</b>')}</div>
    </div>`;
  }catch(e){
    document.getElementById(typingId)?.remove();
    chatEl.innerHTML+=`<div style="margin-bottom:8px">
      <div style="display:inline-block;background:var(--card2);border-radius:12px 12px 12px 2px;padding:8px 12px;font-size:13px;color:var(--red)">❌ Error connecting to AI. Check internet and try again.</div>
    </div>`;
  }
  chatEl.scrollTop=chatEl.scrollHeight;
}

