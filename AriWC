<script>
// ══════════════════════════════════════════
// INDEXEDDB SETUP
// ══════════════════════════════════════════
let db;
const DB_NAME = 'AWCWireDB';
const DB_VERSION = 2;
const STORES = ['customers','orders','accounts','production','rawstock','salesstock','recipes','quotations','payables'];

function initDB(){
  return new Promise((resolve,reject)=>{
    const req = indexedDB.open(DB_NAME, DB_VERSION);
    req.onupgradeneeded = e => {
      const d = e.target.result;
      STORES.forEach(s => {
        if(!d.objectStoreNames.contains(s)){
          d.createObjectStore(s, {keyPath:'id'});
        }
      });
    };
    req.onsuccess = e => { db = e.target.result; resolve(); };
    req.onerror = e => reject(e);
  });
}

function dbGet(store){
  return new Promise((resolve,reject)=>{
    const tx = db.transaction(store,'readonly');
    const req = tx.objectStore(store).getAll();
    req.onsuccess = e => resolve(e.target.result||[]);
    req.onerror = e => reject(e);
  });
}

function dbPut(store, item){
  return new Promise((resolve,reject)=>{
    const tx = db.transaction(store,'readwrite');
    const req = tx.objectStore(store).put(item);
    req.onsuccess = () => resolve();
    req.onerror = e => reject(e);
  });
}

function dbDelete(store, id){
  return new Promise((resolve,reject)=>{
    try{
      const tx = db.transaction(store,'readwrite');
      // Try string id first, then as-is
      const req = tx.objectStore(store).delete(String(id));
      req.onsuccess = () => resolve();
      req.onerror = e => {
        // Try without string conversion
        const tx2 = db.transaction(store,'readwrite');
        const req2 = tx2.objectStore(store).delete(id);
        req2.onsuccess = () => resolve();
        req2.onerror = e2 => reject(e2);
      };
    }catch(e){ reject(e); }
  });
}

// ══════════════════════════════════════════
