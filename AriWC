async function saveOrder(){
  const custId=document.getElementById('ao-cust').value;
  const isMTO=document.getElementById('ao-mto-toggle').checked;
  let product='', salesStockId='';

  if(isMTO){
    product=document.getElementById('ao-product').value.trim();
    if(!product){showToast('Product description required','var(--red)');return;}
  } else {
    const sel=document.getElementById('ao-stock-select');
    salesStockId=sel.value;
    product=sel.options[sel.selectedIndex]?.text||'';
    if(!salesStockId){showToast('Select a wire from stock','var(--red)');return;}
    // Check available stock
    const stocks=await dbGet('salesstock');
    const stock=stocks.find(s=>s.id===salesStockId);
    const qty=parseInt(document.getElementById('ao-qty').value)||0;
    if(stock && qty>stock.bundles){
      if(!await awcConfirm('Stock insufficient!','Only '+stock.bundles+' bundles available. Order '+qty+'?')) return;
    }
  }

  if(!product){showToast('Product required','var(--red)');return;}
  const custs=await dbGet('customers');
  const cust=custs.find(c=>c.id===custId);
  const total=parseFloat(document.getElementById('ao-total').value)||0;
  const advance=parseFloat(document.getElementById('ao-advance').value)||0;

  // Credit limit check
  if(cust&&cust.creditLimit>0){
    const orders=await dbGet('orders');
    const outstanding=orders.filter(o=>o.custId===custId&&o.status==='pending').reduce((s,o)=>s+(o.balance||0),0);
    if(outstanding+total>cust.creditLimit){
      if(!await awcConfirm('Credit limit exceeded!',`Outstanding: ${fmt(outstanding)} + Order: ${fmt(total)} > Limit: ${fmt(cust.creditLimit)}`)) return;
    }
  }

  await dbPut('orders',{
    id:uid(),custId,custName:cust?cust.name:'Walk-in',
    product,qty:parseFloat(document.getElementById('ao-qty').value)||0,
    unit:document.getElementById('ao-unit').value,
    rate:parseFloat(document.getElementById('ao-rate').value)||0,
    total,advance,balance:total-advance,
    deliveryDate:document.getElementById('ao-date').value,
    notes:document.getElementById('ao-notes').value.trim(),
    status:'pending',madeToOrder:isMTO,salesStockId,stockDeducted:false,
    created:new Date().toISOString()
  });
  closeModal('modal-addorder');
  ['ao-product','ao-qty','ao-rate','ao-total','ao-advance','ao-notes'].forEach(id=>document.getElementById(id).value='');
  renderOrders();
  showToast('Order saved ✓');
}

