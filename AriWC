      <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:6px">
        <div style="font-size:11px;font-weight:700;color:var(--gold)">ITEM ${i+1}</div>
        ${_challanItems.length>1?`<button onclick="removeChallanItem(${i})" style="background:none;border:none;color:var(--red);cursor:pointer;font-size:16px">✕</button>`:''}
      </div>
      <div class="fg"><div class="lbl">Wire Brand / Description</div>
        <input class="inp" value="${item.brand||''}" oninput="_challanItems[${i}].brand=this.value" placeholder="e.g. Kaveri 1.5sqmm FR Red" style="background:#1c1c1c;color:#f2ede8;-webkit-text-fill-color:#f2ede8;-webkit-appearance:none;appearance:none;">
      </div>
      <div class="row2">
        <div class="fg"><div class="lbl">Bundle Length</div>
          <input class="inp" value="${item.bundleLen||''}" oninput="_challanItems[${i}].bundleLen=this.value" placeholder="90m" style="background:#1c1c1c;color:#f2ede8;-webkit-text-fill-color:#f2ede8;-webkit-appearance:none;appearance:none;">
        </div>
        <div class="fg"><div class="lbl">Qty (Bundles)</div>
          <input class="inp" type="number" value="${item.qty||''}" oninput="_challanItems[${i}].qty=parseFloat(this.value)||0;updateChallanTotal()" placeholder="0" style="background:#1c1c1c;color:#f2ede8;-webkit-text-fill-color:#f2ede8;-webkit-appearance:none;appearance:none;">
        </div>
      </div>
      <div class="row2">
        <div class="fg"><div class="lbl">Rate (₹)</div>
          <input class="inp" type="number" value="${item.rate||''}" oninput="_challanItems[${i}].rate=parseFloat(this.value)||0;_challanItems[${i}].total=_challanItems[${i}].qty*_challanItems[${i}].rate;updateChallanTotal()" placeholder="0" style="background:#1c1c1c;color:#f2ede8;-webkit-text-fill-color:#f2ede8;-webkit-appearance:none;appearance:none;">
        </div>
        <div class="fg"><div class="lbl">Amount (₹)</div>
          <input class="inp" type="number" value="${item.total||''}" oninput="_challanItems[${i}].total=parseFloat(this.value)||0;updateChallanTotal()" placeholder="0" style="background:#1c1c1c;color:#f2ede8;-webkit-text-fill-color:#f2ede8;-webkit-appearance:none;appearance:none;">
        </div>
      </div>
    </div>`).join('');
  updateChallanTotal();
}

function addChallanItem(){
  _challanItems.push({brand:'',bundleLen:'',qty:1,rate:0,total:0});
  renderChallanItems();
}

function removeChallanItem(i){
  _challanItems.splice(i,1);
  renderChallanItems();
}

function updateChallanTotal(){
  const curr=_challanItems.reduce((s,x)=>s+(x.total||0),0);
  const prev=parseFloat(document.getElementById('challan-prev-bal')?.value)||0;
  const grand=curr+prev;
  const el1=document.getElementById('challan-curr-total');
  const el2=document.getElementById('challan-prev-display');
  const el3=document.getElementById('challan-grand-total');
  if(el1) el1.textContent=fmt(curr);
  if(el2) el2.textContent=fmt(prev);
  if(el3) el3.textContent=fmt(grand);
}

async function generateChallan(){
  const orders=await dbGet('orders');
  const o=orders.find(x=>x.id===_challanOrderId);
  if(!o){showToast('Order not found','var(--red)');return;}

  const prevBal=parseFloat(document.getElementById('challan-prev-bal').value)||0;
  const currTotal=_challanItems.reduce((s,x)=>s+(x.total||0),0);
  const grandTotal=currTotal+prevBal;
  const totalQty=_challanItems.reduce((s,x)=>s+(parseInt(x.qty)||0),0);
  const challanNo='CH-'+Date.now().toString().slice(-6);
  const challanDate=new Date().toLocaleDateString('en-IN',{day:'2-digit',month:'long',year:'numeric'});

  const {jsPDF}=window.jspdf;
  const doc=new jsPDF({orientation:'portrait',unit:'mm',format:'a4',compress:true});
  const W=doc.internal.pageSize.getWidth();
  const H=doc.internal.pageSize.getHeight();
  const ML=16, MR=16, TW=W-ML-MR;

  // HEADER — dark background
  doc.setFillColor(17,17,17);
  doc.roundedRect(ML,10,TW,28,3,3,'F');

  // AWC title
  doc.setFont('helvetica','bold');
  doc.setFontSize(22);
  doc.setTextColor(200,134,10);
  doc.text('AWC',ML+6,24);

  // Company info
  doc.setFont('helvetica','normal');
  doc.setFontSize(8);
  doc.setTextColor(170,170,170);
  doc.text('Gujarat, India',ML+6,29);
  doc.text('+91 XXXXX XXXXX',ML+6,33.5);

  // Challan title right side
  doc.setFont('helvetica','bold');
  doc.setFontSize(13);
  doc.setTextColor(255,255,255);
  doc.text('DELIVERY CHALLAN',W-MR-6,22,{align:'right'});
  doc.setFont('helvetica','normal');
  doc.setFontSize(8.5);
  doc.setTextColor(170,170,170);
  doc.text('Challan No:  '+challanNo,W-MR-6,27.5,{align:'right'});
  doc.text('Date:  '+challanDate,W-MR-6,32.5,{align:'right'});

  let y=44;

  // FROM / TO box
  doc.setFillColor(248,248,246);
  doc.roundedRect(ML,y,TW,22,2,2,'F');
  doc.setDrawColor(204,204,204);
  doc.roundedRect(ML,y,TW,22,2,2,'S');
  // Divider
  doc.setDrawColor(204,204,204);
  doc.line(ML+TW/2,y,ML+TW/2,y+22);

  // FROM
  doc.setFont('helvetica','bold'); doc.setFontSize(7); doc.setTextColor(200,134,10);
  doc.text('FROM',ML+6,y+6);
  doc.setFont('helvetica','bold'); doc.setFontSize(11); doc.setTextColor(17,17,17);
  doc.text('AWC',ML+6,y+12);
  doc.setFont('helvetica','normal'); doc.setFontSize(9); doc.setTextColor(85,85,85);
  doc.text('Gujarat, India',ML+6,y+17.5);

  // TO
  doc.setFont('helvetica','bold'); doc.setFontSize(7); doc.setTextColor(200,134,10);
  doc.text('TO',ML+TW/2+6,y+6);
  doc.setFont('helvetica','bold'); doc.setFontSize(11); doc.setTextColor(17,17,17);
  doc.text(o.custName||'Customer',ML+TW/2+6,y+12);
  doc.setFont('helvetica','normal'); doc.setFontSize(9); doc.setTextColor(85,85,85);
  doc.text(o.custPhone||'',ML+TW/2+6,y+17.5);

  y+=28;

  // TABLE HEADER
  const cols=[11,TW*0.42,24,22,26,TW-(11+TW*0.42+24+22+26)];
  const colX=[ML];
  cols.forEach((w,i)=>{ if(i>0) colX.push(colX[i-1]+cols[i-1]); });

  doc.setFillColor(17,17,17);
  doc.rect(ML,y,TW,9,'F');
  doc.setFont('helvetica','bold'); doc.setFontSize(8); doc.setTextColor(255,255,255);
  const headers=['SR','WIRE BRAND / DESCRIPTION','BUNDLE LENGTH','QTY (Bdls)','RATE (Rs.)','AMOUNT (Rs.)'];
  const hAligns=['center','left','center','center','right','right'];
  headers.forEach((h,i)=>{
    const cx = hAligns[i]==='center' ? colX[i]+cols[i]/2 :
               hAligns[i]==='right'  ? colX[i]+cols[i]-2 : colX[i]+2;
    doc.text(h,cx,y+5.5,{align:hAligns[i]});
  });
  y+=9;

  // TABLE ROWS
  _challanItems.forEach((item,idx)=>{
    const bg = idx%2===0 ? [255,255,255] : [248,248,246];
    doc.setFillColor(...bg);
    doc.rect(ML,y,TW,9,'F');
    doc.setDrawColor(204,204,204);
    doc.rect(ML,y,TW,9,'S');
    doc.setFont('helvetica','normal'); doc.setFontSize(9); doc.setTextColor(17,17,17);

    const rowVals=[
      {v:String(idx+1),a:'center'},
      {v:item.brand||'—',a:'left'},
      {v:item.bundleLen||'—',a:'center'},
      {v:String(item.qty||0),a:'center'},
      {v:(item.rate||0).toLocaleString('en-IN'),a:'right'},
      {v:(item.total||0).toLocaleString('en-IN'),a:'right'},
    ];
    rowVals.forEach((rv,i)=>{
      const cx = rv.a==='center' ? colX[i]+cols[i]/2 :
                 rv.a==='right'  ? colX[i]+cols[i]-2 : colX[i]+2;
      // Truncate long text
      let txt=rv.v;
      if(i===1 && txt.length>30) txt=txt.slice(0,28)+'..';
      doc.text(txt,cx,y+6,{align:rv.a});
    });
    if(idx===_challanItems.length-1) doc.setFont('helvetica','bold');
    y+=9;
  });

  y+=3;

  // TOTALS BOX
  const totW=TW*0.5;
  const totX=ML+TW-totW;

  // Current delivery
  doc.setFillColor(248,248,246);
  doc.rect(totX,y,totW,8,'F');
  doc.setDrawColor(204,204,204);
  doc.rect(totX,y,totW,8,'S');
  doc.setFont('helvetica','normal'); doc.setFontSize(9); doc.setTextColor(85,85,85);
  doc.text('Total Bundles:',totX+3,y+5.5);
  doc.setFont('helvetica','bold'); doc.setTextColor(17,17,17);
  doc.text(totalQty+' Bundles',totX+totW-3,y+5.5,{align:'right'});
  y+=8;

  doc.setFillColor(248,248,246);
  doc.rect(totX,y,totW,8,'F');
  doc.setDrawColor(204,204,204);
  doc.rect(totX,y,totW,8,'S');
  doc.setFont('helvetica','normal'); doc.setFontSize(9); doc.setTextColor(85,85,85);
  doc.text('Current Delivery:',totX+3,y+5.5);
  doc.setFont('helvetica','bold'); doc.setTextColor(17,17,17);
  doc.text('Rs. '+currTotal.toLocaleString('en-IN')+'/-',totX+totW-3,y+5.5,{align:'right'});
  y+=8;

  if(prevBal>0){
    doc.setFillColor(255,248,248);
    doc.rect(totX,y,totW,8,'F');
    doc.setDrawColor(255,180,180);
    doc.rect(totX,y,totW,8,'S');
    doc.setFont('helvetica','normal'); doc.setFontSize(9); doc.setTextColor(180,50,0);
    doc.text('Previous Balance:',totX+3,y+5.5);
    doc.setFont('helvetica','bold');
    doc.text('Rs. '+prevBal.toLocaleString('en-IN')+'/-',totX+totW-3,y+5.5,{align:'right'});
    y+=8;
  }

  // Grand total — dark row
  doc.setFillColor(17,17,17);
  doc.rect(totX,y,totW,11,'F');
  doc.setFont('helvetica','bold'); doc.setFontSize(10); doc.setTextColor(255,255,255);
  doc.text('TOTAL PAYABLE:',totX+3,y+7.5);
  doc.setFont('helvetica','bold'); doc.setFontSize(11); doc.setTextColor(200,134,10);
  doc.text('Rs. '+grandTotal.toLocaleString('en-IN')+'/-',totX+totW-3,y+7.5,{align:'right'});
  y+=18;

  // SIGNATURE BOX
  doc.setFillColor(248,248,246);
  doc.roundedRect(ML,y,TW,28,2,2,'F');
  doc.setDrawColor(204,204,204);
  doc.roundedRect(ML,y,TW,28,2,2,'S');
  doc.line(ML+TW/2,y,ML+TW/2,y+28);

  doc.setFont('helvetica','normal'); doc.setFontSize(8.5); doc.setTextColor(85,85,85);
  doc.text('Customer Signature & Stamp',ML+6,y+7);
  doc.setDrawColor(170,170,170);
  doc.line(ML+6,y+20,ML+TW/2-8,y+20);
  doc.setFont('helvetica','bold'); doc.setFontSize(9); doc.setTextColor(17,17,17);
  doc.text(o.custName||'Customer',ML+6,y+24.5);
  doc.setFont('helvetica','oblique'); doc.setFontSize(8); doc.setTextColor(85,85,85);
  doc.text('Received goods in good condition',ML+6,y+27.5);

  doc.setFont('helvetica','normal'); doc.setFontSize(8.5); doc.setTextColor(85,85,85);
  doc.text('For AWC',W-MR-6,y+7,{align:'right'});
  doc.line(ML+TW/2+8,y+20,W-MR-6,y+20);
  doc.setFont('helvetica','bold'); doc.setFontSize(9); doc.setTextColor(17,17,17);
  doc.text('Authorised Signatory',W-MR-6,y+24.5,{align:'right'});
  doc.setFont('helvetica','oblique'); doc.setFontSize(8); doc.setTextColor(85,85,85);
  doc.text('AWC',W-MR-6,y+27.5,{align:'right'});
  y+=28;

  // FOOTER — ensure within page bounds
  if(y > H-20) y = H-20; // Safety clamp
  doc.setDrawColor(200,200,200);
  doc.line(ML,y,W-MR,y);
  y+=5;
  doc.setFont('helvetica','bold'); doc.setFontSize(8); doc.setTextColor(122,69,0);
  doc.text('This is a Proforma Invoice only. Original Tax Invoice will follow within 15 days.',W/2,y,{align:'center'});
  y+=4;
  doc.setFont('helvetica','oblique'); doc.setFontSize(7.5); doc.setTextColor(170,170,170);
  doc.text('Thank you for your business!',W/2,y,{align:'center'});

  // Delete any extra blank pages
  const pageCount=doc.internal.getNumberOfPages();
  if(pageCount>1){
    for(let i=pageCount;i>1;i--) doc.deletePage(i);
  }

  // Save and store for WhatsApp
  const filename='AWC_Challan_'+challanNo+'_'+(o.custName||'Customer').replace(/[^a-zA-Z0-9]/g,'_')+'.pdf';
  window._lastChallanPDF = doc.output('datauristring');
  window._lastChallanName = filename;
  doc.save(filename);
  showToast('Challan downloaded ✓');
}

