async function renderPnL(){
  // Populate month selector if empty
  const sel=document.getElementById('pnl-month');
  if(!sel) return;
  if(!sel.options.length){
    const now=new Date();
    for(let i=0;i<12;i++){
      const d=new Date(now.getFullYear(),now.getMonth()-i,1);
      const val=d.toISOString().slice(0,7);
      const label=d.toLocaleDateString('en-IN',{month:'long',year:'numeric'});
      const opt=document.createElement('option');
      opt.value=val; opt.textContent=label;
      sel.appendChild(opt);
    }
  }
  const month=sel.value||new Date().toISOString().slice(0,7);
  const all=await dbGet('accounts');

  // Filter current month
  const monthData=all.filter(a=>a.date&&a.date.startsWith(month));
  const income=monthData.filter(a=>a.type==='income').reduce((s,a)=>s+a.amount,0);
  const expense=monthData.filter(a=>a.type==='expense').reduce((s,a)=>s+a.amount,0);
  const profit=income-expense;
  const margin=income>0?((profit/income)*100):0;

  document.getElementById('pnl-income').textContent=fmt(income);
  document.getElementById('pnl-expense').textContent=fmt(expense);
  const profEl=document.getElementById('pnl-profit');
  profEl.textContent=fmt(Math.abs(profit));
  profEl.style.color=profit>=0?'var(--green)':'var(--red)';
  profEl.parentElement.querySelector('.stat-lbl').textContent=profit>=0?'Net Profit':'Net Loss';
  const margEl=document.getElementById('pnl-margin');
  margEl.textContent=margin.toFixed(1)+'%';
  margEl.style.color=margin>=0?'var(--green)':'var(--red)';

  // Expense breakdown
  const cats={};
  monthData.filter(a=>a.type==='expense').forEach(a=>{
    const c=a.category||'other';
    cats[c]=(cats[c]||0)+a.amount;
  });
  const breakdown=Object.entries(cats).sort((a,b)=>b[1]-a[1]);
  const catLabels={sales:'Sales',raw_material:'Raw Material',salary:'Salary',
    rent:'Rent',electricity:'Electricity',transport:'Transport',
    loan_emi:'Loan EMI',maintenance:'Maintenance',other:'Other',other_fixed:'Fixed Expense'};
  document.getElementById('pnl-breakdown').innerHTML=breakdown.length?
    breakdown.map(([cat,amt])=>`
      <div style="display:flex;justify-content:space-between;align-items:center;padding:7px 0;border-bottom:1px solid var(--border)">
        <div style="font-size:12px;color:var(--muted)">${catLabels[cat]||cat}</div>
        <div style="font-size:13px;font-weight:700;color:var(--red)">${fmt(amt)}</div>
      </div>`).join('')
    :'<div style="font-size:12px;color:var(--muted);text-align:center;padding:12px">No expenses this month</div>';

  // 6-month chart
  await drawPnLChart(all);
}

async function drawPnLChart(allAccounts){
  const canvas=document.getElementById('pnl-chart');
  if(!canvas) return;
  const ctx=canvas.getContext('2d');
  const W=canvas.offsetWidth||300;
  canvas.width=W; canvas.height=180;
  ctx.clearRect(0,0,W,180);

  const months=[];
  const now=new Date();
  for(let i=5;i>=0;i--){
    const d=new Date(now.getFullYear(),now.getMonth()-i,1);
    months.push({
      key:d.toISOString().slice(0,7),
      label:d.toLocaleDateString('en-IN',{month:'short'})
    });
  }

  const data=months.map(m=>{
    const md=allAccounts.filter(a=>a.date&&a.date.startsWith(m.key));
    const inc=md.filter(a=>a.type==='income').reduce((s,a)=>s+a.amount,0);
    const exp=md.filter(a=>a.type==='expense').reduce((s,a)=>s+a.amount,0);
    return {label:m.label,income:inc,expense:exp,profit:inc-exp};
  });

  const maxVal=Math.max(...data.flatMap(d=>[d.income,d.expense]),1);
  const pad={t:10,b:30,l:10,r:10};
  const chartH=180-pad.t-pad.b;
  const chartW=W-pad.l-pad.r;
  const barW=chartW/months.length;
  const bw=barW*0.25;

  // Grid lines
  ctx.strokeStyle='#2a2a2a'; ctx.lineWidth=0.5;
  for(let i=0;i<=4;i++){
    const y=pad.t+chartH*(1-i/4);
    ctx.beginPath(); ctx.moveTo(pad.l,y); ctx.lineTo(W-pad.r,y); ctx.stroke();
  }

  data.forEach((d,i)=>{
    const x=pad.l+i*barW+barW/2;
    const drawBar=(val,color,offset)=>{
      if(!val) return;
      const h=Math.max(2,(val/maxVal)*chartH);
      const y=pad.t+chartH-h;
      ctx.fillStyle=color;
      ctx.beginPath();
      ctx.roundRect(x+offset,y,bw,h,2);
      ctx.fill();
    };
    drawBar(d.income,'#3dba7a',-bw-1);
    drawBar(d.expense,'#e05050',1);

    // Profit dot
    if(d.income||d.expense){
      const py=pad.t+chartH-(Math.max(0,d.profit)/maxVal)*chartH;
      ctx.fillStyle=d.profit>=0?'#e8a020':'#e05050';
      ctx.beginPath(); ctx.arc(x,py,3,0,Math.PI*2); ctx.fill();
    }

    // Label
    ctx.fillStyle='#888'; ctx.font='9px sans-serif'; ctx.textAlign='center';
    ctx.fillText(d.label,x,180-8);
  });

  // Legend
  const legend=[['#3dba7a','Income'],['#e05050','Expense'],['#e8a020','Profit']];
  legend.forEach(([color,label],i)=>{
    const lx=pad.l+i*(W/3);
    ctx.fillStyle=color; ctx.fillRect(lx,2,8,8);
    ctx.fillStyle='#888'; ctx.font='9px sans-serif'; ctx.textAlign='left';
    ctx.fillText(label,lx+10,10);
  });
}

