async function saveSupplierPayment(){
  const id=document.getElementById('ps-payable-id').value;
  const amount=parseFloat(document.getElementById('ps-amount').value)||0;
  const date=document.getElementById('ps-date').value;
  const mode=document.getElementById('ps-mode').value;
  if(!amount){showToast('Enter amount','var(--red)');return;}

  const all=await dbGet('payables');
  const p=all.find(x=>x.id===id);
  if(!p) return;
  p.paid=(p.paid||0)+amount;
  p.balance=Math.max(0,p.totalBill-p.paid);
  await dbPut('payables',p);

  // Auto add to accounts as expense
  await dbPut('accounts',{
    id:uid(),type:'expense',amount,
    category:'raw_material',
    desc:`Payment to ${p.supplier} — ${p.material||'materials'} (${mode})`,
    date,custId:'',custName:'',supplierName:p.supplier,
    created:new Date().toISOString()
  });

  closeModal('modal-paysupplier');
  renderSupplier();
  refreshDash();
  showToast(`₹${amount.toLocaleString('en-IN')} paid to ${p.supplier} ✓`);
}

