  closeModal('modal-addrawstock');
  renderRawStock();
}

async function renderRawStock(){
  const all=await dbGet('rawstock');
  const el=document.getElementById('raw-stock-list');
  if(!all.length){el.innerHTML=`<div class="empty"><div class="empty-icon">🗄</div><div class="empty-text">No raw material stock entries yet</div></div>`;return;}

  const groups={metal:[],pvc:[],masterbatch:[]};
  all.forEach(r=>{ if(groups[r.matType]) groups[r.matType].push(r); });

  let html='';
  const labels={metal:'🔩 Metal',pvc:'🧪 PVC Compound',masterbatch:'🎨 Masterbatch'};
  Object.entries(groups).forEach(([type,items])=>{
    if(!items.length) return;
    html+=`<div class="lbl" style="margin:14px 0 6px">${labels[type]}</div>`;
    items.sort((a,b)=>new Date(a.dateReceived)-new Date(b.dateReceived)).forEach(r=>{
      const remaining=r.remaining||0;
      const isLow=r.minStock>0&&remaining<=r.minStock;
      const isWarn=r.minStock>0&&remaining<=r.minStock*1.5;
      const title=type==='metal'?`${r.metalType}${r.supplier?' ('+r.supplier+')':''} — ${r.dia}mm`:type==='pvc'?`${r.supplier} / ${r.grade}`:`${r.supplier} / ${r.grade} (${r.colour})`;
      html+=`<div class="card2 ${isLow?'stock-low':isWarn?'stock-warn':''}">
        <div style="display:flex;justify-content:space-between;align-items:start">
          <div>
            <div style="font-size:13px;font-weight:700">${title}</div>
            <div style="font-size:11px;color:var(--muted)">Remaining: <strong style="color:${isLow?'var(--red)':'var(--green)'}">${remaining.toFixed(1)} kg</strong> / ${r.qty} kg</div>
            ${type==='metal'?`<div style="font-size:11px;color:var(--muted)">Bobbins: ${r.bobbins||0}</div>`:''}
            <div style="font-size:11px;color:var(--muted)">₹${r.price}/kg · ${r.dateReceived}</div>
            ${isLow?'<div style="font-size:10px;color:var(--red);font-weight:700;margin-top:3px">⚠️ LOW STOCK</div>':''}
          </div>
          <div style="display:flex;flex-direction:column;gap:4px">
            <button onclick="editRawStock('${r.id}')" style="background:none;border:1px solid var(--gold);color:var(--gold);padding:3px 7px;border-radius:4px;font-size:10px;cursor:pointer">✏️</button>
