async function renderInsights(){
  const el=document.getElementById('insights-content');
  el.innerHTML=`<div class="empty"><div class="empty-icon">⏳</div><div class="empty-text">Analysing your data...</div></div>`;

  const [orders,production,salesstock,accounts]=await Promise.all([
    dbGet('orders'),dbGet('production'),dbGet('salesstock'),dbGet('accounts')
  ]);

  // ── Product frequency ──
  const prodFreq={};
  orders.filter(o=>o.status!=='cancelled').forEach(o=>{
    const key=o.product||'Unknown';
    if(!prodFreq[key]) prodFreq[key]={name:key,orders:0,revenue:0,qty:0};
    prodFreq[key].orders++;
    prodFreq[key].revenue+=o.total||0;
    prodFreq[key].qty+=parseInt(o.qty)||0;
  });
  const topProducts=Object.values(prodFreq).sort((a,b)=>b.orders-a.orders).slice(0,5);

  // ── Slow moving stock ──
  const now=new Date();
  const slowStock=salesstock.filter(s=>{
    if(!s.bundles||s.bundles<=0) return false;
    const lastProd=new Date(s.lastProduced||s.firstProduced||now);
    const days=(now-lastProd)/(1000*60*60*24);
    return days>30;
  });

  // ── Monthly trend ──
  const thisMonth=today().slice(0,7);
  const lastMonth=new Date(now.getFullYear(),now.getMonth()-1,1).toISOString().slice(0,7);
  const thisIncome=accounts.filter(a=>a.type==='income'&&a.date?.startsWith(thisMonth)).reduce((s,a)=>s+a.amount,0);
  const lastIncome=accounts.filter(a=>a.type==='income'&&a.date?.startsWith(lastMonth)).reduce((s,a)=>s+a.amount,0);
  const thisExpense=accounts.filter(a=>a.type==='expense'&&a.date?.startsWith(thisMonth)).reduce((s,a)=>s+a.amount,0);
  const lastExpense=accounts.filter(a=>a.type==='expense'&&a.date?.startsWith(lastMonth)).reduce((s,a)=>s+a.amount,0);
  const growthPct=lastIncome>0?(((thisIncome-lastIncome)/lastIncome)*100):0;

  // ── Pending collections ──
  const pendingOrders=orders.filter(o=>o.status!=='cancelled'&&(o.balance||0)>0);
  const totalPending=pendingOrders.reduce((s,o)=>s+(o.balance||0),0);

  // Build insights HTML
  let html='';

  // Growth card
  html+=`<div class="card" style="margin-bottom:10px;border-left:3px solid ${growthPct>=0?'var(--green)':'var(--red)'}">
    <div style="font-size:11px;color:var(--gold);font-weight:700;margin-bottom:4px">📊 MONTHLY PERFORMANCE</div>
    <div style="display:flex;justify-content:space-between">
      <div><div class="lbl">This Month</div><div style="font-size:15px;font-weight:800;color:var(--green)">${fmt(thisIncome)}</div></div>
      <div><div class="lbl">Last Month</div><div style="font-size:15px;font-weight:800">${fmt(lastIncome)}</div></div>
      <div><div class="lbl">Growth</div><div style="font-size:15px;font-weight:800;color:${growthPct>=0?'var(--green)':'var(--red)'}">${growthPct>=0?'+':''}${growthPct.toFixed(1)}%</div></div>
    </div>
  </div>`;

  // Top products
  if(topProducts.length){
    html+=`<div class="card" style="margin-bottom:10px">
      <div style="font-size:11px;color:var(--gold);font-weight:700;margin-bottom:8px">🏆 TOP PRODUCTS BY ORDER FREQUENCY</div>
      ${topProducts.map((p,i)=>`
        <div style="display:flex;justify-content:space-between;align-items:center;padding:7px 0;border-bottom:1px solid var(--border)">
          <div style="display:flex;align-items:center;gap:8px">
            <div style="width:22px;height:22px;border-radius:50%;background:${i===0?'var(--gold)':i===1?'#aaa':i===2?'#c8762a':'var(--card3)'};display:flex;align-items:center;justify-content:center;font-size:10px;font-weight:800">${i+1}</div>
            <div>
              <div style="font-size:12px;font-weight:700">${p.name.length>28?p.name.slice(0,26)+'..':p.name}</div>
              <div style="font-size:10px;color:var(--muted)">${p.orders} orders · ${p.qty} units</div>
            </div>
          </div>
          <div style="text-align:right">
            <div style="font-size:12px;font-weight:700;color:var(--gold)">${fmt(p.revenue)}</div>
          </div>
        </div>`).join('')}
    </div>`;
  }

  // Pending collections alert
  if(totalPending>0){
    html+=`<div class="card" style="margin-bottom:10px;border-left:3px solid var(--red)">
      <div style="font-size:11px;color:var(--red);font-weight:700;margin-bottom:6px">⚠️ PENDING COLLECTIONS — ${fmt(totalPending)}</div>
      ${pendingOrders.slice(0,4).map(o=>`
        <div style="display:flex;justify-content:space-between;padding:5px 0;border-bottom:1px solid var(--border)">
          <div style="font-size:12px">${o.custName||'—'}</div>
          <div style="font-size:12px;font-weight:700;color:var(--red)">${fmt(o.balance)}</div>
        </div>`).join('')}
      ${pendingOrders.length>4?`<div style="font-size:11px;color:var(--muted);margin-top:4px">+${pendingOrders.length-4} more</div>`:''}
    </div>`;
  }

  // Slow moving stock
  if(slowStock.length){
    html+=`<div class="card" style="margin-bottom:10px;border-left:3px solid var(--orange)">
      <div style="font-size:11px;color:var(--orange);font-weight:700;margin-bottom:6px">📦 SLOW MOVING STOCK (30+ days)</div>
      ${slowStock.slice(0,3).map(s=>`
        <div style="display:flex;justify-content:space-between;padding:5px 0;border-bottom:1px solid var(--border)">
          <div style="font-size:12px">${s.brand||'—'}</div>
          <div style="font-size:12px;font-weight:700;color:var(--orange)">${s.bundles} bundles</div>
        </div>`).join('')}
    </div>`;
  }

  // Smart recommendations
  html+=`<div class="card" style="margin-bottom:10px;background:linear-gradient(135deg,#1a1400,#141414)">
    <div style="font-size:11px;color:var(--gold);font-weight:700;margin-bottom:8px">💡 SMART RECOMMENDATIONS</div>
    ${topProducts[0]?`<div style="font-size:12px;color:var(--text);margin-bottom:6px;padding:6px;background:var(--card3);border-radius:8px">🎯 <b>${topProducts[0].name.split(' ').slice(0,4).join(' ')}</b> is your best seller — ensure stock is always ready</div>`:''}
    ${slowStock.length?`<div style="font-size:12px;color:var(--text);margin-bottom:6px;padding:6px;background:var(--card3);border-radius:8px">📢 Consider pricing offer on slow stock to free up capital</div>`:''}
    ${growthPct<0?`<div style="font-size:12px;color:var(--text);margin-bottom:6px;padding:6px;background:var(--card3);border-radius:8px">📉 Revenue down ${Math.abs(growthPct).toFixed(1)}% — review pricing & follow up pending orders</div>`:''}
    ${thisExpense>thisIncome?`<div style="font-size:12px;color:var(--text);padding:6px;background:var(--card3);border-radius:8px">⚠️ Expenses exceed income this month — review variable costs</div>`:''}
    ${!topProducts.length&&!slowStock.length&&growthPct>=0?`<div style="font-size:12px;color:var(--green);padding:6px;background:var(--card3);border-radius:8px">✅ Business looks healthy — keep logging data for better insights</div>`:''}
  </div>`;

  el.innerHTML=html||`<div class="empty"><div class="empty-icon">📊</div><div class="empty-text">Add more orders and production data<br>for meaningful insights</div></div>`;
}

