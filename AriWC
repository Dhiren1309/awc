  const dateReceived=document.getElementById('rs-date').value||today();
  let entry={id:uid(),matType,price,dateReceived,invoice:document.getElementById('rs-invoice').value.trim(),supplierPhone:document.getElementById('rs-supplier-phone').value.trim(),minStock:parseFloat(document.getElementById('rs-min-stock').value)||0,created:new Date().toISOString()};

  // Declare qty outside blocks so it's accessible after
  let qty=0;

  if(matType==='metal'){
    const bobbins=parseFloat(document.getElementById('rs-bobbins').value)||0;
    const kgPerBobbin=parseFloat(document.getElementById('rs-kg-per-bobbin').value)||0;
