function calcRsBalance(){
  // Read qty from correct field based on material type
  const matType=document.getElementById('rs-mattype')?.value||'metal';
  let qty=0;
  if(matType==='metal'){
    const bobbins=parseFloat(document.getElementById('rs-bobbins')?.value)||0;
    const kgPerBobbin=parseFloat(document.getElementById('rs-kg-per-bobbin')?.value)||0;
    const manualKg=parseFloat(document.getElementById('rs-metal-kg')?.value)||0;
    qty=manualKg||(bobbins*kgPerBobbin);
  } else if(matType==='pvc'){
    qty=parseFloat(document.getElementById('rs-pvc-kg')?.value)||0;
  } else {
    qty=parseFloat(document.getElementById('rs-mb-kg')?.value)||0;
  }
  const price=parseFloat(document.getElementById('rs-price')?.value)||0;
  const paid=parseFloat(document.getElementById('rs-paid')?.value)||0;
  const total=qty*price;
  const bal=Math.max(0,total-paid);
  const tbEl=document.getElementById('rs-totalbill');
  const balRow=document.getElementById('rs-balance-row');
  const balEl=document.getElementById('rs-balance-display');
  if(tbEl) tbEl.value=total>0?total.toFixed(2):'';
  if(balRow) balRow.style.display=bal>0?'block':'none';
  if(balEl) balEl.textContent=fmt(bal);
}

