  p.brand=document.getElementById('ed-brand').value.trim()||p.brand;
  p.bundles=parseFloat(document.getElementById('ed-bundles').value)||p.bundles;
  p.bundleWt=parseFloat(document.getElementById('ed-bundlewt').value)||p.bundleWt;
  p.actualTotalWt=p.bundleWt*p.bundles;
  p.innerPvcUsed=parseFloat(document.getElementById('ed-innerpvc').value)||0;
  p.outerPvcUsed=parseFloat(document.getElementById('ed-outerpvc').value)||0;
  await dbPut('production',p);
  closeModal('modal-edit');
  closeModal('modal-vieworder');
