async function autoDeductMetal(entry){
  // Deduct based on metal type + strand dia using FIFO
  const all=await dbGet('rawstock');
  const metalType=entry.metalType.toLowerCase().replace(' ','_').replace('-','_');
  const strandDia=parseFloat(entry.strandDia)||0;
  // Calculate theory metal consumed
  const km=entry.metalType.includes('Aluminium')?2.121:entry.metalType.includes('CCS')?6.283:7.037;
  const strands=parseFloat(entry.strands)||7;
  const metalWtPerBundle=strands*strandDia*strandDia*km*entry.bundleLen;
  const totalMetalKg=(metalWtPerBundle*entry.bundles)/1000;

  let remaining=totalMetalKg;
  // FIFO — sort by date
  const matching=all.filter(r=>r.matType==='metal'&&Math.abs((r.dia||0)-strandDia)<0.001).sort((a,b)=>new Date(a.dateReceived)-new Date(b.dateReceived));
  for(const batch of matching){
    if(remaining<=0) break;
    const available=batch.remaining!=null?batch.remaining:batch.qty;
    const deduct=Math.min(available,remaining);
    batch.remaining=Math.max(0,available-deduct);
    remaining-=deduct;
    await dbPut('rawstock',batch);
  }
}

async function autoDeductPVC(entry){
  const all=await dbGet('rawstock');

  // ── Deduct PVC ──
  const supplier=entry.pvcSupplier;
  const grade=entry.pvcGrade;
  const totalPVC=(entry.innerPvcUsed||0)+(entry.outerPvcUsed||0);

  if(supplier && grade && totalPVC>0){
    const pvcBatches=all
      .filter(r=>r.matType==='pvc' && r.supplier===supplier && r.grade===grade)
      .sort((a,b)=>new Date(a.dateReceived||a.created)-new Date(b.dateReceived||b.created));

    let remaining=totalPVC;
    for(const batch of pvcBatches){
      if(remaining<=0) break;
      const available=batch.remaining!=null?batch.remaining:(batch.qty||0);
      const deduct=Math.min(available, remaining);
      batch.remaining=Math.max(0, available-deduct);
      remaining-=deduct;
      await dbPut('rawstock',batch);
    }
    if(remaining>0){
      showToast('⚠️ PVC short by '+(remaining).toFixed(1)+'kg — update stock','var(--orange)');
    }
  }

  // ── Deduct Masterbatch ──
  const mbUsed=entry.mbUsed||0;
  if(mbUsed>0){
    const mbBatches=all
      .filter(r=>r.matType==='masterbatch')
      .sort((a,b)=>new Date(a.dateReceived||a.created)-new Date(b.dateReceived||b.created));

    let remaining=mbUsed;
    for(const batch of mbBatches){
      if(remaining<=0) break;
      const available=batch.remaining!=null?batch.remaining:(batch.qty||0);
      const deduct=Math.min(available, remaining);
      batch.remaining=Math.max(0, available-deduct);
      remaining-=deduct;
      await dbPut('rawstock',batch);
    }
  }
}

async function autoAddSalesStock(entry){
  const existing=await dbGet('salesstock');
  // Look for matching product
  const key=`${entry.brand}-${entry.finalOD}-${entry.bundleLen}`;
  const found=existing.find(s=>s.key===key);
  if(found){
    found.bundles+=entry.bundles;
    found.lastProduced=entry.date;
    await dbPut('salesstock',found);
  } else {
    await dbPut('salesstock',{
      id:uid(),key,
      brand:entry.brand,wireType:entry.wireType,metalType:entry.metalType,
      finalOD:entry.finalOD,bundleLen:entry.bundleLen,
      bundles:entry.bundles,
      makingPrice:0,sellingPrice:0,
      firstProduced:entry.date,lastProduced:entry.date,
      created:new Date().toISOString()
    });
  }
}

