async function updateOrderStatus(id,status){
  const all=await dbGet('orders');
  const o=all.find(x=>x.id===id);
  if(!o) return;
  const prevStatus=o.status;
  o.status=status;
  await dbPut('orders',o);

  // Deduct from sales stock when marked delivered (only if from stock order and not already deducted)
  if(status==='delivered' && prevStatus!=='delivered' && o.salesStockId && !o.stockDeducted){
    const stocks=await dbGet('salesstock');
    const stock=stocks.find(s=>s.id===o.salesStockId);
    if(stock){
      const qty=parseInt(o.qty)||0;
      stock.bundles=Math.max(0,(stock.bundles||0)-qty);
      await dbPut('salesstock',stock);
      o.stockDeducted=true;
      await dbPut('orders',o);
      showToast('Stock updated: -'+qty+' bundles ✓');
    }
  } else {
    showToast('Status updated ✓');
  }

  closeModal('modal-vieworder');
  renderOrders();
}

