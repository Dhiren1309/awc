    </div>
    <div class="fg"><div class="lbl">Payment Mode</div>
      <select class="inp" id="pay-mode" style="background:#1c1c1c;color:#f2ede8;-webkit-text-fill-color:#f2ede8;-webkit-appearance:none;appearance:none;">
        <option value="cash">Cash</option>
        <option value="upi">UPI / GPay</option>
        <option value="bank">Bank Transfer</option>
        <option value="cheque">Cheque</option>
      </select>
    </div>
    <button class="btn btn-green" onclick="savePayment('${o.id}','${bal}')">✅ SAVE PAYMENT</button>
  `;
  closeModal('modal-vieworder');
  openModal('modal-edit');
}

async function savePayment(orderId, balStr){
  const amount=parseFloat(document.getElementById('pay-amount').value)||0;
  if(!amount){showToast('Enter amount','var(--red)');return;}
  const date=document.getElementById('pay-date').value;
  const mode=document.getElementById('pay-mode').value;
  const bal=parseFloat(balStr)||0;

  // Update order balance
  const orders=await dbGet('orders');
  const o=orders.find(x=>x.id===orderId);
  if(!o) return;
  const newAdv=(o.advance||0)+amount;
  const newBal=Math.max(0,(o.total||0)-newAdv);
  o.advance=newAdv;
  o.balance=newBal;
  if(newBal<=0) o.status='delivered';
  await dbPut('orders',o);

  // Add to accounts as income
  const custs=await dbGet('customers');
  const cust=custs.find(c=>c.id===o.custId);
  await dbPut('accounts',{
    id:uid(),type:'income',amount,
    category:'sales',
    desc:`Payment received — ${o.product||'Order'} (${mode})`,
    date,custId:o.custId,custName:o.custName||'',
    supplierName:'',created:new Date().toISOString()
  });

  closeModal('modal-edit');
  showToast(`₹${amount.toLocaleString('en-IN')} received ✓`);
  refreshDash();
  renderOrders();
}

