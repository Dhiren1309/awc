async function checkFixedExpenses(){
  try{
    const all=await dbGet('accounts');
    const fixed=all.filter(a=>a.isFixed);
    if(!fixed.length) return;
    const thisMonth=today().slice(0,7);
    const uniqueFixed=[...new Map(fixed.map(f=>[f.fixedId,f])).values()];
    for(const f of uniqueFixed){
      const alreadyPosted=all.some(a=>a.isFixed&&a.fixedId===f.fixedId&&a.date&&a.date.startsWith(thisMonth)&&a.id!==f.id);
      if(!alreadyPosted){
        const originalThisMonth=f.date&&f.date.startsWith(thisMonth);
        if(!originalThisMonth){
          await dbPut('accounts',{
            id:uid(),type:'expense',amount:f.amount,
            category:f.category,desc:f.fixedName||f.desc,
            date:today(),custId:'',custName:'',supplierName:'',
            isFixed:true,fixedId:f.fixedId,fixedName:f.fixedName||f.desc,
            created:new Date().toISOString()
          });
        }
      }
    }
  }catch(e){ console.log('Fixed expenses:',e); }
}


