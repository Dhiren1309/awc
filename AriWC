  } else if(matType==='pvc'){
    qty=parseFloat(document.getElementById('rs-pvc-kg').value)||0;
    if(!qty){showToast('Enter PVC quantity','var(--red)');return;}
    entry={...entry,supplier:document.getElementById('rs-pvc-supplier').value.trim(),grade:document.getElementById('rs-pvc-grade').value.trim(),qty,remaining:qty};
  } else {
    qty=parseFloat(document.getElementById('rs-mb-kg').value)||0;
    if(!qty){showToast('Enter masterbatch quantity','var(--red)');return;}
    entry={...entry,supplier:document.getElementById('rs-mb-supplier').value.trim(),grade:document.getElementById('rs-mb-grade').value.trim(),colour:document.getElementById('rs-mb-colour').value,qty,remaining:qty};
  }

  await dbPut('rawstock',entry);

  // Auto-create supplier payable if balance due
  const totalBillAmt=qty*price;
  const paidAmt=parseFloat(document.getElementById('rs-paid')?.value)||0;
  const balDue=totalBillAmt-paidAmt;
  const supplierName=entry.supplier||'Unknown Supplier';
  if(balDue>0){
    await dbPut('payables',{
      id:uid(),
      supplier:supplierName,
      material:matType==='metal'?`${entry.metalType} ${entry.dia}mm`:
               matType==='pvc'?`PVC ${entry.grade}`:
               `Masterbatch ${entry.grade}`,
      totalBill:totalBillAmt,
      paid:paidAmt,
      balance:balDue,
      dueDate:'',
      notes:`Auto from stock entry ${entry.dateReceived}`,
      rawStockId:entry.id,
      created:new Date().toISOString()
    });
    showToast('Stock added + ₹'+fmtK(balDue)+' due recorded ✓');
  } else {
    showToast('Stock added ✓');
